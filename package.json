{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "install:all": "npm ci --prefix backend && npm ci --prefix frontend && npm install",
    "lint": "eslint backend/src/**/*.js backend/server.js frontend/src/**/*.{jsx,js} frontend/vite.config.js",
    "format": "prettier --write \"backend/src/**/*.js\" \"backend/server.js\" \"frontend/src/**/*.{jsx,js,css}\" \"frontend/vite.config.js\"",
    "format:check": "prettier --check \"backend/src/**/*.js\" \"backend/server.js\" \"frontend/src/**/*.{jsx,js,css}\" \"frontend/vite.config.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "prettier": "^3.0.0"
  }
}
